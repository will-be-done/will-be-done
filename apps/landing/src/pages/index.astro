<script>
  // Mouse parallax
  document.addEventListener('mousemove', (e) => {
    const x = (e.clientX / window.innerWidth - 0.5) * 2;
    const y = (e.clientY / window.innerHeight - 0.5) * 2;
    document.querySelectorAll<HTMLElement>('[data-parallax]').forEach((el) => {
      const rot = el.dataset.rotate ?? '0';
      const mx = parseFloat(el.dataset.mx ?? '0');
      const my = parseFloat(el.dataset.my ?? '0');
      const isVideoWrapper = el.style.transform.includes('translate(-50%, -50%)');
      if (isVideoWrapper) {
        el.style.transform = `translate(-50%, -50%) translate(${x * mx}px, ${y * my}px)`;
      } else {
        el.style.transform = `rotate(${rot}deg) translate(${x * mx}px, ${y * my}px)`;
      }
    });
  });

  // Video modal
  const modal = document.getElementById('video-modal') as HTMLDialogElement;
  const modalVideo = document.getElementById('modal-video') as HTMLVideoElement;

  document.querySelectorAll('[data-open-modal]').forEach((btn) => {
    btn.addEventListener('click', () => {
      modal.showModal();
      modalVideo.play();
      window.posthog?.capture('demo_video_opened');
    });
  });

  document.getElementById('close-modal')?.addEventListener('click', () => {
    modal.close();
    modalVideo.pause();
    modalVideo.currentTime = 0;
    window.posthog?.capture('demo_video_closed');
  });

  modal.addEventListener('click', (e) => {
    if (e.target === modal) {
      modal.close();
      modalVideo.pause();
      modalVideo.currentTime = 0;
      window.posthog?.capture('demo_video_closed');
    }
  });

  // PostHog: CTA and link click tracking
  document.querySelectorAll<HTMLAnchorElement>('[data-ph-event]').forEach((el) => {
    el.addEventListener('click', () => {
      const event = el.dataset.phEvent!;
      const props: Record<string, string> = {};
      if (el.dataset.phSection) props['section'] = el.dataset.phSection;
      window.posthog?.capture(event, props);
    });
  });

  // Screenshot carousel
  (() => {
    const SLIDE_COUNT = 5;
    const AUTO_INTERVAL = 4500;
    let current = 0;
    let timer: ReturnType<typeof setInterval> | null = null;
    let fillGeneration = 0;
    let dotStartTime = 0;

    const slides = document.querySelectorAll<HTMLElement>('.carousel-slide');
    const captions = document.querySelectorAll<HTMLElement>('.carousel-caption');
    const dots = document.querySelectorAll<HTMLElement>('.carousel-dot');
    const dotFills = document.querySelectorAll<HTMLElement>('.carousel-dot-fill');

    function startFillAnimation() {
      const gen = ++fillGeneration;
      dotStartTime = performance.now();

      dotFills.forEach((fill) => {
        fill.style.transition = 'none';
        fill.style.width = '0%';
      });

      const activeFill = dotFills[current] as HTMLElement;

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          if (gen !== fillGeneration) return;
          activeFill.style.transition = `width ${AUTO_INTERVAL}ms linear`;
          activeFill.style.width = '100%';
        });
      });
    }

    function goTo(index: number) {
      const prev = current;
      current = ((index % SLIDE_COUNT) + SLIDE_COUNT) % SLIDE_COUNT;

      if (prev !== current) {
        const delta = ((current - prev) + SLIDE_COUNT) % SLIDE_COUNT;
        const forward = delta <= Math.floor(SLIDE_COUNT / 2);

        const enterFrom = forward ? 'translateX(8%) scale(0.97)' : 'translateX(-8%) scale(0.97)';
        const exitTo = forward ? 'translateX(-5%) scale(0.97)' : 'translateX(5%) scale(0.97)';
        const standby = forward ? 'translateX(8%) scale(0.97)' : 'translateX(-8%) scale(0.97)';

        // Instantly reposition entering slide without transition
        const enteringSlide = slides[current];
        enteringSlide.style.transition = 'none';
        enteringSlide.style.transform = enterFrom;
        enteringSlide.style.opacity = '0';
        enteringSlide.style.zIndex = '10';

        // Animate exiting slide out
        const exitingSlide = slides[prev];
        exitingSlide.style.opacity = '0';
        exitingSlide.style.transform = exitTo;
        exitingSlide.style.zIndex = '5';
        setTimeout(() => { exitingSlide.style.zIndex = '0'; }, 700);

        // Park other slides in the correct standby position
        slides.forEach((slide, i) => {
          if (i !== current && i !== prev) {
            slide.style.opacity = '0';
            slide.style.transform = standby;
            slide.style.zIndex = '0';
          }
        });

        // After browser commits the instant position, animate entering slide in
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            enteringSlide.style.transition = '';
            enteringSlide.style.transform = 'translateX(0%) scale(1)';
            enteringSlide.style.opacity = '1';
          });
        });
      }

      captions.forEach((cap, i) => {
        cap.style.opacity = i === current ? '1' : '0';
        cap.style.transform = i === current ? 'translateY(0)' : 'translateY(8px)';
      });

      dots.forEach((dot, i) => {
        (dot as HTMLElement).style.width = i === current ? '28px' : '14px';
      });

      startFillAnimation();
    }

    function startAuto() {
      if (timer) clearInterval(timer);
      timer = setInterval(() => goTo(current + 1), AUTO_INTERVAL);
    }

    document.getElementById('carousel-prev')?.addEventListener('click', () => {
      goTo(current - 1);
      startAuto();
    });

    document.getElementById('carousel-next')?.addEventListener('click', () => {
      goTo(current + 1);
      startAuto();
    });

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        goTo(parseInt(dot.dataset.dot ?? '0'));
        startAuto();
      });
    });

    // Pause on hover
    const carouselEl = document.getElementById('carousel');
    carouselEl?.addEventListener('mouseenter', () => {
      if (timer) clearInterval(timer);
      const activeFill = dotFills[current] as HTMLElement;
      const elapsed = performance.now() - dotStartTime;
      const pct = Math.min((elapsed / AUTO_INTERVAL) * 100, 100);
      ++fillGeneration; // Cancel any pending rAF
      activeFill.style.transition = 'none';
      activeFill.style.width = `${pct}%`;
    });
    carouselEl?.addEventListener('mouseleave', () => {
      startAuto();
      startFillAnimation();
    });

    // Init
    goTo(0);
    startAuto();
  })();
</script>
